<%- include('../../partials/header.ejs') %>
<section class="pcoded-main-container">
    <div class="pcoded-content">
        <div class="page-header">
            <h5>All Tasks</h5>
        </div>
        <div class="card">
            <div class="card-body">
                <form method="GET" action="/admin/viewTasks" class="mb-3 d-flex">
                    <input type="text" name="search" class="form-control me-2" placeholder="Search task..."
                        value="<%= search || '' %>">
                    <button type="submit" class="btn btn-primary">Search</button>
                </form>
                <div class="d-flex justify-content-between mb-3">
                    <h4>Task List</h4>
                    <% if(user.role !=='employee' ){ %>
                        <a href="/admin/addTask" class="btn btn-success">+ Add Task</a>
                     <% } %>
                </div>
                <div class="table-responsive">
                    <table class="table table-bordered text-center">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Task Name</th>
                                <th>Description</th>
                                <th>Assigned To</th>
                                <th>Assigned By</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>

                        <tbody>

                            <% if (tasks && tasks.length> 0) { %>

                                <% tasks.forEach((task, index)=> { %>

                                    <tr>
                                        <td>
                                            <%= index + 1 %>
                                        </td>

                                        <td>
                                            <%= task.name %>
                                        </td>

                                        <td>
                                            <%= task.description %>
                                        </td>

                                        <td>
                                            <%= task.assignedTo?.name || 'N/A' %>
                                        </td>

                                        <td>
                                            <%= task.createdBy?.name || 'N/A' %>
                                        </td>

                                        <td>
                                            <% if(task.status==='pending approval' ){ %>
                                                <span class="badge bg-warning">Approval Pending</span>
                                                <% } else if(task.status==='completed' ){ %>
                                                    <span class="badge bg-success">Completed</span>
                                                    <% } else { %>
                                                        <span class="badge bg-info">
                                                            <%= task.status %>
                                                        </span>
                                                        <% } %>
                                        </td>

                                        <td>

                                            <!-- ADMIN + MANAGER APPROVE -->
                                            <% if ((user.role==='admin' || user.role==='manager' ) &&
                                                task.status==='pending approval' ) { %>

                                                <a href="/admin/approve/<%= task._id %>" class="btn btn-success btn-sm">
                                                    Approve
                                                </a>

                                                <% } else { %>

                                                    <!-- NORMAL ACTIONS -->
                                                    <a href="/admin/editTask/<%= task._id %>"
                                                        class="btn btn-info btn-sm">
                                                        Edit
                                                    </a>

                                                    <a href="/admin/deleteTask/<%= task._id %>"
                                                        class="btn btn-danger btn-sm">
                                                        Delete
                                                    </a>

                                                    <% } %>

                                        </td>
                                    </tr>

                                    <% }) %>

                                        <% } else { %>

                                            <tr>
                                                <td colspan="7">No Tasks Found</td>
                                            </tr>

                                            <% } %>

                        </tbody>

                    </table>
                </div>
            </div>
        </div>
    </div>
</section>
<%- include('../../partials/footer.ejs') %>