<%- include('../../partials/header.ejs') %>

<section class="pcoded-main-container">
    <div class="pcoded-content">

        <!-- Header -->
        <div class="page-header">
            <h5>Edit Task</h5>
        </div>

        <!-- Form -->
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-body">

                        <h4 class="mb-3 text-center">Update Task</h4>

                        <form action="/admin/editTask/<%= task._id %>" method="POST">

                            <!-- Task Name -->
                            <div class="form-group mb-3">
                                <label>Task Name</label>
                                <input type="text" name="name" class="form-control"
                                       value="<%= task.name %>" required>
                            </div>

                            <!-- Description -->
                            <div class="form-group mb-3">
                                <label>Description</label>
                                <textarea name="description" class="form-control" rows="4" required><%= task.description %></textarea>
                            </div>

                            <!-- Assigned To -->
                            <div class="form-group mb-3">
                                <label>Assign To Employee</label>
                                <select name="assignedTo" class="form-control" required>

                                    <option value="">-- Select Employee --</option>

                                    <% employees.forEach(emp => { %>
                                        <option value="<%= emp._id %>"
                                            <%= task.assignedTo && task.assignedTo._id.toString() === emp._id.toString() ? 'selected' : '' %>>
                                            <%= emp.name %>
                                        </option>
                                    <% }) %>

                                </select>
                            </div>

                            <!-- Buttons -->
                            <div class="mt-3">
                                <button type="submit" class="btn btn-success">
                                    Update Task
                                </button>

                                <a href="/admin/viewTasks" class="btn btn-secondary">
                                    Cancel
                                </a>
                            </div>

                        </form>

                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

<%- include('../../partials/footer.ejs') %>