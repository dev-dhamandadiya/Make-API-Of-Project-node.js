<!DOCTYPE html>
<html lang="en">

<head>
	<title>Ablepro Admin</title>

	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">

	<link rel="icon" href="/assets/images/favicon.ico">
	<link rel="stylesheet" href="/assets/css/style.css">
</head>

<body>

	<!-- Preloader -->
	<div class="loader-bg">
		<div class="loader-track">
			<div class="loader-fill"></div>
		</div>
	</div>

	<!-- ================= SIDEBAR ================= -->
	<nav class="pcoded-navbar menu-light">

		<div class="navbar-wrapper">
			<div class="navbar-content scroll-div">

				<!-- USER INFO -->
				<div class="main-menu-header">
					<img class="img-radius" src="/assets/images/user/avatar-2.jpg">

					<div class="user-details">
						<div id="more-details">
							<%= user?.name %> (<%= user?.role %>)
						</div>
					</div>
				</div>

				<!-- MENU -->
				<ul class="nav pcoded-inner-navbar">

					<!-- DASHBOARD -->
					<li class="nav-item">
						<% if(user.role === 'employee') { %>
							<a href="/employee/dashboard" class="nav-link">
						<% } else { %>
							<a href="/admin/dashboard" class="nav-link">
						<% } %>
						
							<span class="pcoded-micon"><i class="feather icon-home"></i></span>
							<span class="pcoded-mtext">Dashboard</span>
						</a>
					</li>

					<!-- ================= EMPLOYEES ================= -->
					<% if (user.role === 'admin' || user.role === 'manager') { %>

					<li class="nav-item pcoded-hasmenu">
						<a href="#!" class="nav-link">
							<span class="pcoded-micon"><i class="feather icon-users"></i></span>
							<span class="pcoded-mtext">Employees</span>
						</a>

						<ul class="pcoded-submenu">

							<% if (user.role === 'admin') { %>
								<li><a href="/admin/createEmployee">Add Employee</a></li>
							<% } %>

							<li><a href="/admin/viewEmployees">View Employees</a></li>

						</ul>
					</li>

					<% } %>

					<!-- ================= TASKS ================= -->
					<li class="nav-item pcoded-hasmenu">
						<a href="#!">
							<span class="pcoded-micon"><i class="feather icon-clipboard"></i></span>
							<span class="pcoded-mtext">Tasks</span>
						</a>

						<ul class="pcoded-submenu">

							<!-- ADMIN + MANAGER -->
							<% if (user.role === 'admin' || user.role === 'manager') { %>
								<li><a href="/admin/addTask">Add Task</a></li>
								<li><a href="/admin/viewTasks">View Tasks</a></li>
							<% } %>

							<!-- EMPLOYEE -->
							<% if (user.role === 'employee') { %>
								<li><a href="/employee/tasks">My Tasks</a></li>
							<% } %>

						</ul>
					</li>

					<!-- ================= AUTH ================= -->
					<li class="nav-item pcoded-hasmenu">
						<a href="#!">
							<span class="pcoded-micon"><i class="feather icon-lock"></i></span>
							<span class="pcoded-mtext">Authentication</span>
						</a>

						<ul class="pcoded-submenu">
							<li><a href="/admin/login">Login</a></li>
							<li><a href="/admin/signup">Signup</a></li>
						</ul>
					</li>

				</ul>
			</div>
		</div>
	</nav>

	<!-- ================= TOP HEADER ================= -->
	<header class="navbar pcoded-header navbar-expand-lg navbar-light header-blue">

		<div class="m-header">
			<a class="mobile-menu" id="mobile-collapse" href="#!"><span></span></a>
			<a href="/" class="b-brand">
				<img src="/assets/images/logo.png" class="logo">
			</a>
		</div>

		<div class="collapse navbar-collapse">

			<ul class="navbar-nav ml-auto">

				<!-- USER DROPDOWN -->
				<li class="dropdown drp-user">

					<a class="dropdown-toggle" data-toggle="dropdown">
						<i class="feather icon-user"></i>
					</a>

					<div class="dropdown-menu dropdown-menu-right">

						<div class="pro-head">
							<span>
								<%= user?.name %> (<%= user?.role %>)
							</span>
						</div>

						<!-- LOGOUT -->
						<a href="/admin/logout" class="dropdown-item">
							<i class="feather icon-log-out"></i> Logout
						</a>

					</div>

				</li>

			</ul>

		</div>

	</header>